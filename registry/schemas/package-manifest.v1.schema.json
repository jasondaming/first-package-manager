{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://first-toolsuite.github.io/schemas/package-manifest.v1.schema.json",
  "title": "Package Manifest",
  "description": "Schema for a FIRST Package Manager package manifest.",
  "type": "object",
  "required": ["id", "name", "version", "season", "description", "category", "competition", "artifacts"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique package identifier (e.g. wpilib.jdk)."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable package name."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic version string."
    },
    "season": {
      "type": "integer",
      "description": "Competition season year."
    },
    "publisher": {
      "type": "string",
      "description": "Publisher identifier."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Package description."
    },
    "category": {
      "type": "string",
      "enum": [
        "runtime",
        "ide",
        "ide-extension",
        "tool",
        "dashboard",
        "library",
        "firmware",
        "toolchain",
        "documentation",
        "driver",
        "framework",
        "build-system",
        "utility"
      ],
      "description": "Package category."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags."
    },
    "competition": {
      "type": "string",
      "enum": ["Frc", "Ftc"],
      "description": "Target competition program."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier."
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage URL."
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Source repository URL."
    },
    "releaseNotes": {
      "type": "string",
      "description": "Release notes for this version."
    },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/definitions/dependency" },
      "description": "Package dependencies."
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Package IDs that conflict with this package."
    },
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/definitions/artifact" },
      "description": "Platform-specific artifacts keyed by platform ID."
    },
    "install": {
      "$ref": "#/definitions/installInfo",
      "description": "Installation configuration."
    },
    "mavenArtifacts": {
      "$ref": "#/definitions/mavenArtifacts",
      "description": "Maven artifact coordinates for vendor libraries."
    },
    "signature": {
      "type": "string",
      "description": "Cryptographic signature of the manifest."
    },
    "deprecated": {
      "type": "boolean",
      "description": "Whether this package is deprecated."
    },
    "supersededBy": {
      "type": "string",
      "description": "ID of the package that supersedes this one."
    }
  },
  "additionalProperties": false,
  "definitions": {
    "artifact": {
      "type": "object",
      "required": ["url", "sha256", "size"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Download URL."
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$|^placeholder-",
          "description": "SHA-256 hash of the artifact."
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes."
        },
        "archiveType": {
          "type": "string",
          "description": "Archive format (zip, tar.gz, etc.)."
        },
        "extractPath": {
          "type": "string",
          "description": "Subdirectory within the archive to extract."
        },
        "filename": {
          "type": "string",
          "description": "Original filename of the artifact."
        },
        "mirrors": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "Mirror download URLs."
        }
      },
      "additionalProperties": false
    },
    "dependency": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Dependency package ID."
        },
        "versionRange": {
          "type": "string",
          "description": "Acceptable version range."
        },
        "type": {
          "type": "string",
          "enum": ["Required", "Recommended", "Optional"],
          "description": "Dependency importance level."
        },
        "reason": {
          "type": "string",
          "description": "Why this dependency is needed."
        }
      },
      "additionalProperties": false
    },
    "installInfo": {
      "type": "object",
      "properties": {
        "installDir": {
          "type": "string",
          "description": "Subdirectory name within the install root."
        },
        "requiresAdmin": {
          "type": "boolean",
          "description": "Whether admin/root elevation is required."
        },
        "postInstall": {
          "type": "array",
          "items": { "$ref": "#/definitions/postInstallAction" },
          "description": "Actions to run after extraction."
        }
      },
      "additionalProperties": false
    },
    "postInstallAction": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1,
          "description": "Action type (set-env, add-to-path, create-shortcut, run-command)."
        },
        "platform": {
          "type": "string",
          "description": "Platform this action applies to (null for all)."
        },
        "params": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Action parameters."
        }
      },
      "additionalProperties": false
    },
    "mavenArtifacts": {
      "type": "object",
      "properties": {
        "vendordepJson": {
          "type": "string",
          "description": "URL to the vendordep JSON file."
        },
        "repositories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Maven repository URLs."
        },
        "coordinates": {
          "type": "array",
          "items": { "$ref": "#/definitions/mavenCoordinate" },
          "description": "Maven artifact coordinates."
        },
        "runMetadataFixer": {
          "type": "boolean",
          "description": "Whether to run the metadata fixer after install."
        }
      },
      "additionalProperties": false
    },
    "mavenCoordinate": {
      "type": "object",
      "required": ["groupId", "artifactId", "version"],
      "properties": {
        "groupId": {
          "type": "string",
          "minLength": 1
        },
        "artifactId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "classifiers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sha256": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
