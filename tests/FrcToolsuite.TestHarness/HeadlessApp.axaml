<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:FrcToolsuite.Gui.Converters"
             x:Class="FrcToolsuite.TestHarness.HeadlessApp"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#5B8DEF" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.accent-white">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#3A5BA0" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#FEF0F0" />
      <Setter Property="Foreground" Value="#CC4444" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.installed">
      <Setter Property="Background" Value="#E8F5E9" />
      <Setter Property="Foreground" Value="#44BB88" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.ghost-white">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
    </Style>
  </Application.Styles>
  <Application.Resources>
    <conv:StringEqualConverter x:Key="StringEqualConverter" />
    <conv:StringToBrushConverter x:Key="StringToBrushConverter" />
    <conv:GreaterThanConverter x:Key="GreaterThanConverter" />
    <conv:InclusionBrushConverter x:Key="InclusionBrushConverter" />
    <conv:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter" />
    <conv:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter" />
  </Application.Resources>
</Application>
