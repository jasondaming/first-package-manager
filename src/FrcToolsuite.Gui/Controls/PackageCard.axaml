<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="180"
             x:Class="FrcToolsuite.Gui.Controls.PackageCard"
             x:DataType="vm:PackageViewModel">

    <Border Background="#FFFFFF"
            CornerRadius="10"
            Padding="18"
            Margin="0,0,0,0"
            BoxShadow="0 2 6 0 #18000000"
            BorderBrush="#E0E4EA"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="52,*">
            <!-- Colored circle icon with first letter -->
            <Border Grid.Row="0" Grid.Column="0"
                    Grid.RowSpan="2"
                    Width="42" Height="42"
                    CornerRadius="21"
                    Background="{Binding IconColor, Converter={StaticResource StringToBrushConverter}}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,0,12,0">
                <TextBlock Text="{Binding IconLetter}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Name, publisher, and category badge -->
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="3">
                <Grid ColumnDefinitions="*,Auto">
                    <Button Grid.Column="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Command="{Binding $parent[ItemsControl].((vm:BrowsePageViewModel)DataContext).ViewDetailCommand}"
                            CommandParameter="{Binding}">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#5B8DEF"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Styles>
                                <Style Selector="TextBlock:pointerover">
                                    <Setter Property="TextDecorations" Value="Underline" />
                                </Style>
                            </TextBlock.Styles>
                        </TextBlock>
                    </Button>
                    <!-- Category badge -->
                    <Border Grid.Column="1"
                            CornerRadius="8"
                            Padding="8,2"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Background="{Binding CategoryBadgeBackground, Converter={StaticResource StringToBrushConverter}}">
                        <TextBlock Text="{Binding Category}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding CategoryBadgeForeground, Converter={StaticResource StringToBrushConverter}}" />
                    </Border>
                </Grid>
                <TextBlock Text="{Binding Publisher}"
                           FontSize="11"
                           Foreground="#888899" />
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding Description}"
                       FontSize="12"
                       Foreground="#556677"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       Margin="0,6,0,8" />

            <!-- Bottom row: version, size, install button -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Version}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Size}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <!-- Admin badge -->
                <Border Grid.Column="2"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        Background="#FFF3E0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding RequiresAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="3">
                        <TextBlock Text="&#x1F6E1;"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Admin"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#E65100"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Grid.Column="3"
                        Classes="accent"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        IsVisible="{Binding !IsInstalled}"
                        IsEnabled="{Binding !IsInstalling}"
                        Command="{Binding InstallCommand}"
                        Content="Install" />
                <TextBlock Grid.Column="3"
                           Text="Installing..."
                           FontSize="11"
                           Foreground="#5B8DEF"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsInstalling}" />
                <Button Grid.Column="3"
                        Content="Installed"
                        Classes="installed"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        IsVisible="{Binding IsInstalled}"
                        IsEnabled="False" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
