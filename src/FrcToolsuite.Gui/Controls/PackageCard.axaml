<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="180"
             x:Class="FrcToolsuite.Gui.Controls.PackageCard"
             x:DataType="vm:PackageViewModel">

    <Border Background="#FFFFFF"
            CornerRadius="10"
            Padding="18"
            Margin="0,0,0,0"
            BoxShadow="0 2 6 0 #18000000"
            BorderBrush="#E0E4EA"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="52,*">
            <!-- Colored circle icon with first letter -->
            <Border Grid.Row="0" Grid.Column="0"
                    Grid.RowSpan="2"
                    Width="42" Height="42"
                    CornerRadius="21"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,0,12,0">
                <Border.Background>
                    <SolidColorBrush Color="{Binding IconColor}" />
                </Border.Background>
                <TextBlock Text="{Binding IconLetter}"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Name, publisher, and category badge -->
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="3">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1A1A2E"
                               TextTrimming="CharacterEllipsis" />
                    <!-- Category badge -->
                    <Border Grid.Column="1"
                            CornerRadius="8"
                            Padding="8,2"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="{Binding CategoryBadgeBackground}" />
                        </Border.Background>
                        <TextBlock Text="{Binding Category}"
                                   FontSize="10"
                                   FontWeight="SemiBold">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{Binding CategoryBadgeForeground}" />
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Border>
                </Grid>
                <TextBlock Text="{Binding Publisher}"
                           FontSize="11"
                           Foreground="#888899" />
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding Description}"
                       FontSize="12"
                       Foreground="#556677"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       Margin="0,6,0,8" />

            <!-- Bottom row: version, size, install button -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Version}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Size}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <Button Grid.Column="3"
                        Content="Install"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        Background="#5B8DEF"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        IsVisible="{Binding !IsInstalled}" />
                <Button Grid.Column="3"
                        Content="Installed"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        Background="#E8F5E9"
                        Foreground="#44BB88"
                        BorderThickness="0"
                        IsVisible="{Binding IsInstalled}"
                        IsEnabled="False" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
