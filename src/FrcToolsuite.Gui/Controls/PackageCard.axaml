<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="320" d:DesignHeight="160"
             x:Class="FrcToolsuite.Gui.Controls.PackageCard"
             x:DataType="vm:PackageViewModel">

    <Border Background="#FFFFFF"
            CornerRadius="8"
            Padding="16"
            Margin="0,0,0,0"
            BoxShadow="0 1 3 0 #22000000"
            BorderBrush="#E0E4EA"
            BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="48,*">
            <!-- Icon -->
            <Border Grid.Row="0" Grid.Column="0"
                    Grid.RowSpan="2"
                    Width="40" Height="40"
                    CornerRadius="8"
                    Background="#EEF1F8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,0,12,0">
                <TextBlock Text="{Binding Icon}"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Name and publisher -->
            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#1A1A2E" />
                <TextBlock Text="{Binding Publisher}"
                           FontSize="11"
                           Foreground="#888899" />
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding Description}"
                       FontSize="12"
                       Foreground="#556677"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       Margin="0,6,0,8" />

            <!-- Bottom row: version, size, install button -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Version}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Size}"
                           FontSize="11"
                           Foreground="#99AABB"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <Button Grid.Column="3"
                        Content="Install"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        Background="#5B8DEF"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        IsVisible="{Binding !IsInstalled}" />
                <Button Grid.Column="3"
                        Content="Installed"
                        FontSize="12"
                        Padding="16,6"
                        CornerRadius="4"
                        Background="#E8EDF2"
                        Foreground="#667788"
                        BorderThickness="0"
                        IsVisible="{Binding IsInstalled}"
                        IsEnabled="False" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
