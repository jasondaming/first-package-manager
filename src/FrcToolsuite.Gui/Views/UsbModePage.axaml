<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="760"
             x:Class="FrcToolsuite.Gui.Views.UsbModePage"
             x:DataType="vm:UsbModePageViewModel">

    <DockPanel Margin="32,24">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" />
            <TextBlock Text="{Binding Description}"
                       FontSize="13"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Border Background="#EEF6FF"
                    CornerRadius="6"
                    Padding="16,10">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           Foreground="#3366AA" />
            </Border>
        </Border>

        <!-- Progress bar during sync -->
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,8,0,0"
                    IsVisible="{Binding IsSyncing}">
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding SyncProgress}"
                         Height="6"
                         CornerRadius="3" />
            <TextBlock Text="{Binding SyncProgressText}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Drive selector section -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="USB Drive / Target Path"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Refresh Drives"
                                    Command="{Binding RefreshDrivesCommand}"
                                    FontSize="11"
                                    Padding="10,4"
                                    CornerRadius="4" />
                        </Grid>

                        <!-- Detected drives (clickable) -->
                        <ItemsControl ItemsSource="{Binding DetectedDrives}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding $parent[ItemsControl].((vm:UsbModePageViewModel)DataContext).SelectDriveCommand}"
                                            CommandParameter="{Binding}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Margin="0,0,8,4"
                                            CornerRadius="6"
                                            Background="{DynamicResource SubtleBackground}"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1"
                                            Cursor="Hand" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Path (auto-filled or manual entry) -->
                        <TextBox Text="{Binding UsbPath}"
                                 PlaceholderText="Or type a path manually"
                                 FontSize="13" />
                    </StackPanel>
                </Border>

                <!-- Platform checkboxes -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Target Platforms"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <WrapPanel Orientation="Horizontal">
                            <ItemsControl ItemsSource="{Binding Platforms}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:UsbPlatformItem">
                                        <Border Background="{DynamicResource SubtleBackground}" CornerRadius="6"
                                                Padding="12,8" Margin="0,0,10,6"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding Label}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </CheckBox>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Package selector -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="Packages to Sync"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Select All"
                                    Command="{Binding SelectAllCommand}"
                                    FontSize="11"
                                    Padding="8,4"
                                    Margin="0,0,6,0"
                                    CornerRadius="4" />
                            <Button Grid.Column="2"
                                    Content="Select None"
                                    Command="{Binding SelectNoneCommand}"
                                    FontSize="11"
                                    Padding="8,4"
                                    CornerRadius="4" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Packages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:UsbPackageItem">
                                    <Border Padding="4,3" Margin="0,1">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Size}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Size estimate and sync button -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="13" Foreground="{DynamicResource TextSecondary}">
                                <Run Text="Estimated download size: " />
                                <Run Text="{Binding EstimatedSize}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Sync to USB"
                                Command="{Binding SyncToUsbCommand}"
                                IsEnabled="{Binding !IsSyncing}"
                                Classes="accent"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="24,10"
                                CornerRadius="6" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
