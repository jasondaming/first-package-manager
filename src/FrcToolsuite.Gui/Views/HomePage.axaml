<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="600"
             x:Class="FrcToolsuite.Gui.Views.HomePage"
             x:DataType="vm:HomePageViewModel">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="24">
            <!-- Hero Section -->
            <Border CornerRadius="12"
                    Padding="40,36">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#5B8DEF" Offset="0" />
                        <GradientStop Color="#3A5BA0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding WelcomeMessage}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FFFFFF" />
                    <TextBlock Text="Install, update, and manage all your FRC and FTC development tools in one place."
                               FontSize="14"
                               Foreground="#CCDDFF"
                               MaxWidth="500"
                               TextWrapping="Wrap" />
                    <Button Content="Get Started"
                            Classes="accent-white"
                            Margin="0,12,0,0"
                            Padding="24,10"
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="6" />
                </StackPanel>
            </Border>

            <!-- Quick Stats -->
            <Grid ColumnDefinitions="*,*,*" Margin="0,4">
                <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="8" Padding="20,16" Margin="0,0,8,0"
                        BoxShadow="0 1 3 0 #15000000" BorderBrush="#E0E4EA" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding InstalledCount}" FontSize="28" FontWeight="Bold" Foreground="#5B8DEF" />
                        <TextBlock Text="Packages Installed" FontSize="12" Foreground="#888899" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="8" Padding="20,16" Margin="4,0"
                        BoxShadow="0 1 3 0 #15000000" BorderBrush="#E0E4EA" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding UpdateCount}" FontSize="28" FontWeight="Bold" Foreground="#E8A838" />
                        <TextBlock Text="Updates Available" FontSize="12" Foreground="#888899" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="8" Padding="20,16" Margin="8,0,0,0"
                        BoxShadow="0 1 3 0 #15000000" BorderBrush="#E0E4EA" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{Binding DiskUsage}" FontSize="28" FontWeight="Bold" Foreground="#44BB88" />
                        <TextBlock Text="Disk Usage" FontSize="12" Foreground="#888899" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Featured Bundles -->
            <TextBlock Text="Featured Bundles"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1A1A2E"
                       Margin="0,8,0,0" />

            <ItemsControl ItemsSource="{Binding FeaturedBundles}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:FeaturedBundle">
                        <Border Background="#FFFFFF"
                                CornerRadius="8"
                                Padding="20,16"
                                Margin="0,0,12,12"
                                Width="260"
                                BoxShadow="0 1 3 0 #15000000"
                                BorderBrush="#E0E4EA"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Width="36" Height="36"
                                            CornerRadius="8"
                                            Background="#EEF1F8">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1A1A2E" />
                                        <TextBlock Text="{Binding PackageCount, StringFormat='{}{0} packages'}"
                                                   FontSize="11"
                                                   Foreground="#888899" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="#556677"
                                           TextWrapping="Wrap"
                                           MaxLines="2" />
                                <Button Content="Install Bundle"
                                        Classes="accent"
                                        Padding="14,6"
                                        FontSize="12"
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
