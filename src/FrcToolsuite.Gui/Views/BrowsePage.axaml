<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             xmlns:controls="using:FrcToolsuite.Gui.Controls"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="600"
             x:Class="FrcToolsuite.Gui.Views.BrowsePage"
             x:DataType="vm:BrowsePageViewModel">

    <DockPanel Margin="32,24">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Browse Packages"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,16" />

        <!-- Search Bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SearchBarBackground}"
                CornerRadius="8"
                Padding="4"
                Margin="0,0,0,16"
                BoxShadow="0 1 3 0 #15000000"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="1">
            <TextBox Text="{Binding SearchQuery}"
                     Watermark="Search packages..."
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="14"
                     Padding="12,8" />
        </Border>

        <!-- Category Filters -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=All}"
                    Content="All"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="All" />
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=Runtime}"
                    Content="Runtime"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="Runtime" />
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=IDE}"
                    Content="IDE"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="IDE" />
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=Tools}"
                    Content="Tools"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="Tools" />
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=Libraries}"
                    Content="Libraries"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="Libraries" />
            <Button Classes="chip"
                    Classes.active="{Binding FilterCategory, Converter={StaticResource StringEqualConverter}, ConverterParameter=Dashboards}"
                    Content="Dashboards"
                    Command="{Binding SetCategoryCommand}"
                    CommandParameter="Dashboards" />
            <Border Width="1" Background="{DynamicResource CardBorder}" Margin="12,4" />
            <CheckBox IsChecked="{Binding HideInstalled}"
                      Margin="4,0"
                      VerticalAlignment="Center">
                <TextBlock Text="Hide installed" FontSize="12" />
            </CheckBox>
        </StackPanel>

        <!-- Scrollable content: collections + packages -->
        <ScrollViewer>
            <StackPanel>
                <!-- Collections Section -->
                <TextBlock Text="Collections"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,12"
                           IsVisible="{Binding Collections.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" />

                <ItemsControl ItemsSource="{Binding Collections}"
                              IsVisible="{Binding Collections.Count, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                              Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:CollectionViewModel">
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="18"
                                    Margin="0,0,0,10"
                                    BoxShadow="0 1 3 0 #15000000"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <!-- Header row -->
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                        <!-- Colored circle with first letter -->
                                        <Border Width="42" Height="42"
                                                CornerRadius="21"
                                                Background="#5B8DEF"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding IconLetter}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="#FFFFFF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Name + description -->
                                        <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Package count -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PackageCount, StringFormat='{}{0} packages'}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />

                                        <!-- Expand/collapse button -->
                                        <Button Grid.Column="3"
                                                Command="{Binding ToggleExpandedCommand}"
                                                Content="{Binding IsExpanded, Converter={StaticResource BoolToExpandIconConverter}}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="16"
                                                Foreground="{DynamicResource TextMuted}"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0" />

                                        <!-- Install All button -->
                                        <Button Grid.Column="4"
                                                Content="Install All"
                                                Classes="accent"
                                                FontSize="12"
                                                Padding="14,6"
                                                CornerRadius="4"
                                                Command="{Binding InstallAllCommand}"
                                                IsVisible="{Binding !IsInstalled}"
                                                VerticalAlignment="Center" />
                                        <Button Grid.Column="4"
                                                Content="Installed"
                                                Classes="installed"
                                                FontSize="12"
                                                Padding="14,6"
                                                CornerRadius="4"
                                                IsVisible="{Binding IsInstalled}"
                                                IsEnabled="False"
                                                VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- Expanded content: list of individual packages -->
                                    <ItemsControl ItemsSource="{Binding Packages}"
                                                  IsVisible="{Binding IsExpanded}"
                                                  Margin="54,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:PackageViewModel">
                                                <Border Padding="8,6"
                                                        Margin="0,2"
                                                        CornerRadius="4"
                                                        BorderBrush="{DynamicResource SubtleBorder}"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                        <CheckBox IsChecked="{Binding IsInstalled}"
                                                                  IsEnabled="False"
                                                                  VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding Size}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0" />
                                                        <Button Grid.Column="3"
                                                                Content="Install"
                                                                Classes="accent"
                                                                FontSize="11"
                                                                Padding="10,3"
                                                                CornerRadius="3"
                                                                Command="{Binding InstallCommand}"
                                                                IsVisible="{Binding !IsInstalled}"
                                                                VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Individual Packages header -->
                <TextBlock Text="Individual Packages"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,12" />

                <!-- Package Grid -->
                <ItemsControl ItemsSource="{Binding FilteredPackages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:PackageViewModel">
                            <Border Margin="0,0,12,12" Width="320">
                                <controls:PackageCard />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
