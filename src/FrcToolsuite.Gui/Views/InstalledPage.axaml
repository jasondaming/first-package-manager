<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="600"
             x:Class="FrcToolsuite.Gui.Views.InstalledPage"
             x:DataType="vm:InstalledPageViewModel">

    <DockPanel Margin="32,24">
        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Installed Packages"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" />
                <TextBlock FontSize="13"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="0,4,0,0">
                    <Run Text="{Binding InstalledPackages.Count, StringFormat='{}{0} packages'}" />
                    <Run Text=" - " />
                    <Run Text="{Binding TotalSize}" />
                    <Run Text=" total" />
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Package List -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding InstalledPackages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:InstalledPackageViewModel">
                        <Border Background="{DynamicResource CardBackground}"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,8"
                                BoxShadow="0 1 2 0 #10000000"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1">
                            <Grid ColumnDefinitions="48,*,Auto,Auto,Auto">
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        Width="40" Height="40"
                                        CornerRadius="8"
                                        Background="{DynamicResource IconCircleBackground}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <!-- Name and publisher -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="{Binding Publisher}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>

                                <!-- Version -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Version}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,20,0" />

                                <!-- Size -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Size}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,20,0" />

                                <!-- Uninstall button -->
                                <Button Grid.Column="4"
                                        Content="Uninstall"
                                        Command="{Binding $parent[ItemsControl].((vm:InstalledPageViewModel)DataContext).UninstallPackageCommand}"
                                        CommandParameter="{Binding Name}"
                                        Classes="danger"
                                        FontSize="12"
                                        Padding="14,6"
                                        CornerRadius="4"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
