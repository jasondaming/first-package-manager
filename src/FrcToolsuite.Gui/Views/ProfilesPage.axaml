<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="760"
             x:Class="FrcToolsuite.Gui.Views.ProfilesPage"
             x:DataType="vm:ProfilesPageViewModel">

    <DockPanel Margin="32,24">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" />
            <TextBlock Text="{Binding Description}"
                       FontSize="13"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Margin="0,12,0,0"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Border Background="#E8F5E9"
                    CornerRadius="6"
                    Padding="16,10">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           Foreground="#2E7D32" />
            </Border>
        </Border>

        <!-- Progress bar during apply -->
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,8,0,0"
                    IsVisible="{Binding IsApplying}">
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding ApplyProgress}"
                         Height="6"
                         CornerRadius="3" />
            <TextBlock Text="{Binding ApplyProgressText}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="16">
                <!-- Action buttons -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Profile Actions"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <WrapPanel Orientation="Horizontal">
                            <Button Content="Export Profile"
                                    Command="{Binding ExportProfileCommand}"
                                    Classes="accent"
                                    FontSize="13"
                                    Padding="18,8"
                                    Margin="0,0,10,0"
                                    CornerRadius="6" />
                            <Button Content="Import Profile"
                                    Command="{Binding ImportProfileCommand}"
                                    Classes="success"
                                    FontSize="13"
                                    Padding="18,8"
                                    Margin="0,0,10,0"
                                    CornerRadius="6" />
                            <Button Content="Apply Profile"
                                    Command="{Binding ApplyProfileCommand}"
                                    IsEnabled="{Binding HasLoadedProfile}"
                                    Classes="warning"
                                    FontSize="13"
                                    Padding="18,8"
                                    CornerRadius="6" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Profile info card (visible when profile loaded) -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        IsVisible="{Binding HasLoadedProfile}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Loaded Profile"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Name:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding ProfileName}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimary}" />

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Team:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,4,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding ProfileTeamNumber}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,4,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="Season:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,4,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding ProfileSeason}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,4,0,0" />

                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="Created:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,4,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding ProfileCreatedAt}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,4,0,0" />

                            <TextBlock Grid.Row="4" Grid.Column="0"
                                       Text="Notes:"
                                       FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,4,0,0" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                       Text="{Binding ProfileNotes}"
                                       FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Package list (visible when profile loaded) -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,16"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        IsVisible="{Binding HasLoadedProfile}">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}">
                            <Run Text="Packages (" />
                            <Run Text="{Binding ProfilePackages.Count}" />
                            <Run Text=")" />
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding ProfilePackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:ProfilePackageItem">
                                    <Border Padding="8,6"
                                            Margin="0,2"
                                            Background="{DynamicResource SubtleBackground}"
                                            CornerRadius="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Id}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource BadgeBackground}"
                                                    CornerRadius="10"
                                                    Padding="10,3">
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Empty state when no profile loaded -->
                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8"
                        Padding="20,24"
                        BoxShadow="0 1 3 0 #15000000"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        IsVisible="{Binding !HasLoadedProfile}">
                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <Border Width="64" Height="64"
                                CornerRadius="32"
                                Background="{DynamicResource IconCircleBackground}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F465;"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="No profile loaded"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Export your current setup or import a profile from a teammate to get started."
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="360"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
