<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FrcToolsuite.Gui.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1024" d:DesignHeight="640"
             x:Class="FrcToolsuite.Gui.Views.FirstRunWizard"
             x:DataType="vm:FirstRunWizardViewModel">

    <UserControl.Styles>
        <!-- Step dot base -->
        <Style Selector="Border.step-dot">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#E0E4EA" />
        </Style>
        <Style Selector="Border.step-dot TextBlock">
            <Setter Property="Foreground" Value="#99AABB" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.step-active">
            <Setter Property="Background" Value="#5B8DEF" />
        </Style>
        <Style Selector="Border.step-active TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
        <Style Selector="Border.step-done">
            <Setter Property="Background" Value="#4CAF50" />
        </Style>
        <Style Selector="Border.step-done TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <!-- Card style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="BoxShadow" Value="0 1 3 0 #18000000" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Use case card -->
        <Style Selector="Border.usecase-card">
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.usecase-selected">
            <Setter Property="BorderBrush" Value="#5B8DEF" />
            <Setter Property="Background" Value="#F0F5FF" />
        </Style>

        <!-- Primary button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#5B8DEF" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A7CE0" />
        </Style>

        <!-- Secondary button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#E8EDF2" />
            <Setter Property="Foreground" Value="#444444" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#D8DDE4" />
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource ContentBackground}">
        <DockPanel>
            <!-- Step Indicator at Top -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource CardBackground}" Padding="0,16,0,0"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
                <StackPanel HorizontalAlignment="Center" Spacing="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <!-- Step 1 -->
                        <Border Classes="step-dot"
                                Classes.step-active="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=1}"
                                Classes.step-done="{Binding CurrentStep, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}">
                            <TextBlock Text="1" />
                        </Border>
                        <Border Width="40" Height="2" Background="{DynamicResource CardBorder}" VerticalAlignment="Center" />

                        <!-- Step 2 -->
                        <Border Classes="step-dot"
                                Classes.step-active="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=2}"
                                Classes.step-done="{Binding CurrentStep, Converter={StaticResource GreaterThanConverter}, ConverterParameter=2}">
                            <TextBlock Text="2" />
                        </Border>
                        <Border Width="40" Height="2" Background="{DynamicResource CardBorder}" VerticalAlignment="Center" />

                        <!-- Step 3 -->
                        <Border Classes="step-dot"
                                Classes.step-active="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=3}"
                                Classes.step-done="{Binding CurrentStep, Converter={StaticResource GreaterThanConverter}, ConverterParameter=3}">
                            <TextBlock Text="3" />
                        </Border>
                        <Border Width="40" Height="2" Background="{DynamicResource CardBorder}" VerticalAlignment="Center" />

                        <!-- Step 4 -->
                        <Border Classes="step-dot"
                                Classes.step-active="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=4}">
                            <TextBlock Text="4" />
                        </Border>
                    </StackPanel>

                    <!-- Step title with more spacing and larger font -->
                    <TextBlock Text="{Binding StepTitle}"
                               FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,14" />
                </StackPanel>
            </Border>

            <!-- Bottom Button Bar -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource CardBackground}" Padding="32,12"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0"
                            Classes="secondary"
                            Content="Back"
                            Command="{Binding GoBackCommand}"
                            IsVisible="{Binding CanGoBack}"
                            HorizontalAlignment="Left" />

                    <Button Grid.Column="1"
                            Content="&#x2699;  Advanced Setup"
                            Command="{Binding SkipWizardCommand}"
                            Classes="ghost-link"
                            FontSize="12"
                            Padding="12,8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            IsVisible="{Binding CanSkipWizard}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Classes="primary"
                                Content="Next"
                                Command="{Binding GoNextCommand}"
                                IsVisible="{Binding CanGoNext}" />
                        <Button Classes="primary"
                                Content="Install"
                                Command="{Binding BeginInstallCommand}"
                                IsVisible="{Binding ShowInstallButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Panel Margin="48,32">
                    <!-- Step 1: Welcome -->
                    <StackPanel IsVisible="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=1}"
                                Spacing="24" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#x2B50;" FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="Welcome to FIRST Package Manager"
                                   FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" TextAlignment="Center" />
                        <TextBlock Text="Set up your development environment in just a few steps. Choose your competition program to get started."
                                   FontSize="14" Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="440" />

                        <Border Classes="card" HorizontalAlignment="Center" MinWidth="320">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Competition Program" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                <ComboBox ItemsSource="{Binding Programs}"
                                          SelectedItem="{Binding SelectedProgram}"
                                          HorizontalAlignment="Stretch"
                                          FontSize="14" />
                                <TextBlock Text="Select FRC, FTC, or Both if your team participates in multiple programs."
                                           FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Previous Year Installations Warning -->
                        <Border Background="#FFF8E1" CornerRadius="8" Padding="20"
                                BorderBrush="#FFE082" BorderThickness="1"
                                HorizontalAlignment="Center" MinWidth="320" MaxWidth="480">
                            <Border.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="HasPreviousYears" />
                                    <Binding Path="!PreviousYearsDismissed" />
                                </MultiBinding>
                            </Border.IsVisible>
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#x26A0;&#xFE0F;" FontSize="18" VerticalAlignment="Center" />
                                    <TextBlock Text="Previous Installation Found"
                                               FontSize="14" FontWeight="Bold" Foreground="#F57F17"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="We recommend removing old installations to free disk space and avoid version conflicts."
                                           FontSize="12" Foreground="#795548" TextWrapping="Wrap" />

                                <ItemsControl ItemsSource="{Binding PreviousYears}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PreviousYearItem">
                                            <Border Background="#FFFDE7" CornerRadius="4" Padding="10,8" Margin="0,0,0,4"
                                                    BorderBrush="#FFE082" BorderThickness="1">
                                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               FontSize="13" FontWeight="SemiBold" Foreground="#5D4037"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="WPILib {0} ({1})">
                                                                <Binding Path="Year" />
                                                                <Binding Path="SizeDisplay" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <Button Grid.Row="0" Grid.Column="1"
                                                            Content="Remove"
                                                            Classes="warning"
                                                            FontSize="11" Padding="12,4"
                                                            CornerRadius="4"
                                                            Command="{Binding $parent[ItemsControl].((vm:FirstRunWizardViewModel)DataContext).UninstallYearCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsVisible="{Binding !IsRemoved}"
                                                            IsEnabled="{Binding !IsRemoving}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="&#x2713; Removed" FontSize="12"
                                                               Foreground="#2E7D32" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsRemoved}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                               Text="{Binding StatusText}" FontSize="11"
                                                               Foreground="#8D6E63" Margin="0,2,0,0"
                                                               IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                    <Button Content="Remove All Previous Versions"
                                            Classes="danger"
                                            FontSize="11" Padding="14,5"
                                            CornerRadius="4"
                                            Command="{Binding UninstallAllPreviousYearsCommand}" />
                                    <Button Content="Keep All"
                                            Classes="ghost-link"
                                            FontSize="11" Padding="12,4"
                                            Command="{Binding DismissPreviousYearsCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Step 2: Choose Setup (Use Cases + Vendor Selection) -->
                    <StackPanel IsVisible="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=2}"
                                Spacing="20" MaxWidth="700" HorizontalAlignment="Center">

                        <TextBlock Text="WPILib core (JDK, VS Code, GradleRIO, tools) is always included."
                                   FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" />

                        <!-- Use Case Cards -->
                        <TextBlock Text="What are you setting up?" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,4,0,0" />

                        <ItemsControl ItemsSource="{Binding UseCases}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:UseCaseItem">
                                    <Button Command="{Binding $parent[ItemsControl].((vm:FirstRunWizardViewModel)DataContext).SelectUseCaseCommand}"
                                            CommandParameter="{Binding Id}"
                                            Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,8,8"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch">
                                        <Border Classes="usecase-card"
                                                Classes.usecase-selected="{Binding IsSelected}"
                                                Width="330" MinHeight="70">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="28"
                                                           VerticalAlignment="Center" Margin="0,0,14,0" />
                                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimary}" />
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Vendor Packages -->
                        <TextBlock Text="Popular Third-Party Libraries" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,0" />
                        <TextBlock Text="Optional vendor libraries for common FRC hardware and tools."
                                   FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding VendorPackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:VendorPackageItem">
                                    <Border Background="{DynamicResource CardBackground}" CornerRadius="6" Padding="14,10" Margin="0,0,0,4"
                                            BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBorderBrushConverter}}"
                                            BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToBorderThicknessConverter}}">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,10,0" />
                                                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextMuted}" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                                           FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0" />
                                            </Grid>
                                            <!-- Sub-items (e.g., Phoenix Tuner X, REV Hardware Client) -->
                                            <ItemsControl ItemsSource="{Binding SubItems}" IsVisible="{Binding IsSelected}" Margin="32,4,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:VendorSubItem">
                                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                                                       FontSize="11" Foreground="{DynamicResource TextMuted}"
                                                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Step 3: Review -->
                    <StackPanel IsVisible="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=3}"
                                Spacing="20" MaxWidth="560" HorizontalAlignment="Center">

                        <Border Classes="card">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Installing WPILib 2026 Development Environment"
                                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Program:" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                               Margin="0,0,16,8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding SelectedProgram}" FontSize="13" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Location:" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                               Margin="0,0,16,8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding InstallPath}" FontSize="13" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Download:" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                               Margin="0,0,16,8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding TotalDownloadSize}" FontSize="13" FontWeight="Bold" Foreground="#5B8DEF" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Vendor libs:" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"
                                               Margin="0,0,16,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               Text="{Binding SelectedVendorCount, StringFormat='{}{0} selected'}"
                                               FontSize="13" Foreground="{DynamicResource TextPrimary}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Vendor library list (only non-core) -->
                        <TextBlock Text="Selected Vendor Libraries" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                   IsVisible="{Binding SelectedVendorCount}" />
                        <ItemsControl ItemsSource="{Binding VendorPackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:VendorPackageItem">
                                    <Border Padding="8,4" IsVisible="{Binding IsSelected}">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0" Text="&#x2713;" FontSize="13" Foreground="#4CAF50"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- WPILib core info -->
                        <TextBlock Text="WPILib Core (always included)" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0" />
                        <TextBlock Text="JDK 17, VS Code, GradleRIO, WPILib Tools, AdvantageScope"
                                   FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Step 4: Install Progress -->
                    <StackPanel IsVisible="{Binding CurrentStep, Converter={StaticResource StringEqualConverter}, ConverterParameter=4}"
                                Spacing="20" MaxWidth="560" HorizontalAlignment="Center">

                        <!-- Overall progress -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding InstallStatus}"
                                       FontSize="14" Foreground="{DynamicResource TextSecondary}"
                                       HorizontalAlignment="Center" />
                            <ProgressBar Value="{Binding InstallProgress}"
                                         Minimum="0" Maximum="100"
                                         Height="8"
                                         Foreground="#5B8DEF" />
                        </StackPanel>

                        <!-- Per-package progress -->
                        <ItemsControl ItemsSource="{Binding SelectedPackages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:WizardPackageItem">
                                    <Border Background="{DynamicResource CardBackground}" CornerRadius="6" Padding="14,10" Margin="0,0,0,4"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding SizeDisplay}" FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                                <ProgressBar Value="{Binding DownloadProgress}"
                                                             Minimum="0" Maximum="100"
                                                             Height="4"
                                                             Foreground="#5B8DEF"
                                                             IsVisible="{Binding DownloadProgress}" />
                                                <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                           Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="This may take several minutes depending on your internet connection."
                                   FontSize="11" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                   IsVisible="{Binding IsInstalling}" />

                        <!-- Installation Complete message -->
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="20" IsVisible="{Binding InstallComplete}"
                                HorizontalAlignment="Center">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="&#x2713; Installation Complete!" FontSize="18" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center" />
                                <TextBlock Text="Your development environment is ready to use."
                                           FontSize="13" Foreground="#4CAF50" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Panel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
