<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:FrcToolsuite.Gui.Converters"
             x:Class="FrcToolsuite.Gui.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />
    <!-- Fix buttons with custom backgrounds disappearing on hover -->
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#5B8DEF" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4A7CE0" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
      <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#3A6BD0" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
    </Style>
    <Style Selector="Button.accent-white">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#3A5BA0" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#F0F0F0" />
        <Setter Property="Foreground" Value="#3A5BA0" />
      </Style>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#FEF0F0" />
      <Setter Property="Foreground" Value="#CC4444" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#FCDCDC" />
        <Setter Property="Foreground" Value="#CC4444" />
      </Style>
    </Style>
    <Style Selector="Button.installed">
      <Setter Property="Background" Value="#E8F5E9" />
      <Setter Property="Foreground" Value="#44BB88" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#D0ECD2" />
        <Setter Property="Foreground" Value="#44BB88" />
      </Style>
    </Style>
    <Style Selector="Button.ghost-white">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="BorderBrush" Value="#FFFFFF" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#FFFFFF33" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
      </Style>
      <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#FFFFFF55" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
      </Style>
    </Style>
    <Style Selector="Button.success">
      <Setter Property="Background" Value="#44BB88" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#38A878" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
      <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2D9668" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
    </Style>
    <Style Selector="Button.warning">
      <Setter Property="Background" Value="#E8A838" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#D49530" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
      <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#C08428" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
    </Style>
    <Style Selector="Button.ghost-link">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#889AAB" />
      <Setter Property="BorderThickness" Value="0" />
      <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#5B8DEF" />
      </Style>
      <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#3A6BD0" />
      </Style>
    </Style>
    <!-- Make unchecked checkboxes more visible on white backgrounds -->
    <Style Selector="CheckBox:unchecked /template/ Border#NormalRectangle">
      <Setter Property="BorderBrush" Value="#99AABB" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Selector button: invisible Button wrapper that delegates ALL visual
         feedback to the inner element. Use when wrapping a custom card/Border
         that handles its own hover/selected states. -->
    <Style Selector="Button.selector">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.selector /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.selector:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.selector:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Application.Styles>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="SidebarBackground" Color="#1A1A2E" />
          <SolidColorBrush x:Key="SidebarTopBar" Color="#1E1E3A" />
          <SolidColorBrush x:Key="ContentBackground" Color="#F5F6FA" />
          <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
          <SolidColorBrush x:Key="CardBorder" Color="#E0E4EA" />
          <SolidColorBrush x:Key="TextPrimary" Color="#1A1A2E" />
          <SolidColorBrush x:Key="TextSecondary" Color="#556677" />
          <SolidColorBrush x:Key="TextMuted" Color="#889AAB" />
          <SolidColorBrush x:Key="SearchBarBackground" Color="#FFFFFF" />
          <SolidColorBrush x:Key="SubtleBorder" Color="#F0F1F4" />
          <SolidColorBrush x:Key="SubtleBackground" Color="#F8F9FB" />
          <SolidColorBrush x:Key="BadgeBackground" Color="#EEF1F8" />
          <SolidColorBrush x:Key="ChipBackground" Color="#E8EDF2" />
          <SolidColorBrush x:Key="ChipForeground" Color="#444444" />
          <SolidColorBrush x:Key="SidebarDivider" Color="#2A2A4A" />
          <SolidColorBrush x:Key="SidebarHover" Color="#2A2A4A" />
          <SolidColorBrush x:Key="ReleaseNotesBg" Color="#FAFBFC" />
          <SolidColorBrush x:Key="ReleaseNotesBorder" Color="#E8ECF0" />
          <SolidColorBrush x:Key="IconCircleBackground" Color="#EEF1F8" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="SidebarBackground" Color="#0D0D1A" />
          <SolidColorBrush x:Key="SidebarTopBar" Color="#141428" />
          <SolidColorBrush x:Key="ContentBackground" Color="#1A1A2E" />
          <SolidColorBrush x:Key="CardBackground" Color="#242440" />
          <SolidColorBrush x:Key="CardBorder" Color="#333355" />
          <SolidColorBrush x:Key="TextPrimary" Color="#E8E8F0" />
          <SolidColorBrush x:Key="TextSecondary" Color="#AABBCC" />
          <SolidColorBrush x:Key="TextMuted" Color="#778899" />
          <SolidColorBrush x:Key="SearchBarBackground" Color="#242440" />
          <SolidColorBrush x:Key="SubtleBorder" Color="#333355" />
          <SolidColorBrush x:Key="SubtleBackground" Color="#2A2A44" />
          <SolidColorBrush x:Key="BadgeBackground" Color="#2A2A4A" />
          <SolidColorBrush x:Key="ChipBackground" Color="#2A2A4A" />
          <SolidColorBrush x:Key="ChipForeground" Color="#CCCCDD" />
          <SolidColorBrush x:Key="SidebarDivider" Color="#1A1A33" />
          <SolidColorBrush x:Key="SidebarHover" Color="#1A1A33" />
          <SolidColorBrush x:Key="ReleaseNotesBg" Color="#2A2A44" />
          <SolidColorBrush x:Key="ReleaseNotesBorder" Color="#333355" />
          <SolidColorBrush x:Key="IconCircleBackground" Color="#2A2A4A" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
      <conv:StringEqualConverter x:Key="StringEqualConverter" />
      <conv:StringToBrushConverter x:Key="StringToBrushConverter" />
      <conv:GreaterThanConverter x:Key="GreaterThanConverter" />
      <conv:InclusionBrushConverter x:Key="InclusionBrushConverter" />
      <conv:BoolToBorderBrushConverter x:Key="BoolToBorderBrushConverter" />
      <conv:BoolToBorderThicknessConverter x:Key="BoolToBorderThicknessConverter" />
      <conv:BoolToExpandIconConverter x:Key="BoolToExpandIconConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
